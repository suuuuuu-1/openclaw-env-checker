{
  "name": "openclaw-env-checker",
  "version": "1.0.0",
  "type": "module",
  "description": "OpenClaw Manager environment checker",
  "bin": {
    "openclaw-check": "./check-env.js"
  },
  "scripts": {
    "build": "node build.js",
    "package": "pkg dist/check-env.cjs --targets node22-win-x64,node22-macos-x64,node22-macos-arm64,node22-linux-x64 --output dist/openclaw-check --compress Brotli --config pkg.config.json",
    "create-dmg": "./create-app.sh",
    "start": "node server.js"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.5.0",
    "esbuild": "^0.25.0"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "license": "MIT",
  "dependencies": {
    "express": "^5.2.1"
  }
}
